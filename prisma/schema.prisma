generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Models ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── App Models ─────────────────────────────────────────────

enum RestoreStatus {
  PENDING
  RESTORING
  READY
  EXPIRED
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  roleArn            String?
  bucketName         String?
  region             String?   @default("ap-south-1")
  notificationEmail  String?
  restoreDays        Int       @default(7)
  previewQuality     String    @default("720p")
  previewDurationCap Int       @default(60)
  lifecycleDays      Int       @default(7)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  files       File[]
  folders     Folder[]
  restoreJobs RestoreJob[]

  @@map("users")
}

model File {
  id         String   @id @default(cuid())
  userId     String
  name       String
  s3Key      String
  previewKey  String?
  previewSize BigInt?
  size        BigInt
  type       String
  folderPath   String
  originalDate DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, folderPath])
  @@map("files")
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  path      String
  parentId  String?
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[] @relation("FolderTree")

  @@unique([userId, path])
  @@map("folders")
}

model RestoreJob {
  id          String        @id @default(cuid())
  userId      String
  folderPath  String
  keys          Json          @default("[]")
  tier          String?
  estimatedCost Float?
  status        RestoreStatus @default(PENDING)
  fileCount     Int           @default(0)
  totalSize     BigInt        @default(0)
  requestedAt DateTime      @default(now())
  restoredAt  DateTime?
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("restore_jobs")
}
