# Neon Postgres
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Auth.js
AUTH_SECRET="" # npx auth secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# RSA key pair for OIDC JWT signing (RS256)
# Generate with: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt
JWT_PRIVATE_KEY=""
# Extract public key: openssl rsa -pubout
JWT_PUBLIC_KEY=""

# App URL (used as OIDC issuer — must match what's configured in AWS IAM OIDC provider)
NEXT_PUBLIC_APP_URL="" # e.g. https://app.taimumashin.com

# Webhook authentication (must match CloudFormation WebhookSecret parameter)
WEBHOOK_SECRET="" # openssl rand -hex 32
